# terraform — state can contain plaintext secrets; never commit
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars
crash.log

# kubernetes — cluster credentials
kubeconfig
*.kubeconfig
.kube/

# helm — local chart deps pulled at build time
charts/**/charts/
*.tgz

# secrets / signing
.vault_pass
*.vault_pass
*.pem
*.key

# scan / sbom artefacts (not source)
trivy-report.*
*.sbom.json
.snyk-result.json
k6-summary.json
codeql-db/
codeql-results.sarif
zap-report/

# pre-commit
.pre-commit-cache/
# .secrets.baseline is intentionally tracked (suppress known false-positives)

# temp files generated during demos
/tmp/*.json
/tmp/*.spdx.json

__pycache__/
*.pyc
*.php~
node_modules/

# claude
.claude/